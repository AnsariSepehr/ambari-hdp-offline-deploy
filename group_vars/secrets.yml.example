# Example structure for group_vars/secrets.yml
#
# The real file MUST be encrypted with ansible-vault and is gitignored.
# Copy this file, fill in real values, then encrypt it:
#
#   cp group_vars/secrets.yml.example group_vars/secrets.yml
#   ansible-vault encrypt group_vars/secrets.yml
#
# To edit later:
#   ansible-vault edit group_vars/secrets.yml
#
---
vault_nginx_basic_auth_pass: "CHANGEME"
vault_mysql_root_password: "CHANGEME"

vault_ambari_db_user: "ambari"
vault_ambari_db_password: "CHANGEME"
vault_ambari_db_name: "ambari"
vault_ambari_db_host: "CHANGEME"          # e.g. the ambari_server node's hostname

vault_hive_db_root_pass: "CHANGEME"
vault_hive_db_password: "CHANGEME"

vault_ranger_db_root_pass: "CHANGEME"
vault_ranger_db_pass: "CHANGEME"
vault_ranger_db_password: "CHANGEME"

vault_ranger_audit_db_root_pass: "CHANGEME"
vault_ranger_audit_db_pass: "CHANGEME"
vault_ranger_audit_db_password: "CHANGEME"

vault_kerberos_admin_password: "CHANGEME"

vault_mysql_replication_password: "CHANGEME"
